Federal Grant Search - v1
Searches Grants.gov for open federal funding opportunities by keyword.

Usage:
    python grant_search.py "renewable energy"
    python grant_search.py "education" --max-results 20
"""

import argparse
import requests
from datetime import datetime

API_URL = "https://api.grants.gov/v1/api/search2"


def search_grants(keyword, max_results=10):
    """Query the Grants.gov search2 API for a given keyword."""
    payload = {
        "keyword": keyword,
        "rows": max_results,
        "oppStatuses": "forecasted|posted",  # only show open/upcoming grants
    }

    response = requests.post(API_URL, json=payload, timeout=15)
    response.raise_for_status()
    data = response.json()

    return data.get("data", {}).get("oppHits", [])


def format_grant(grant):
    """Pretty-print a single grant result."""
    title = grant.get("title", "Untitled")
    agency = grant.get("agencyName", "Unknown agency")
    opp_number = grant.get("number", "N/A")
    close_date = grant.get("closeDate", "No deadline listed")
    opp_id = grant.get("id")

    link = f"https://www.grants.gov/search-results-detail/{opp_id}" if opp_id else "N/A"

    return (
        f"\n{title}\n"
        f"  Agency:        {agency}\n"
        f"  Opportunity #: {opp_number}\n"
        f"  Closes:        {close_date}\n"
        f"  Link:          {link}\n"
    )


def main():
    parser = argparse.ArgumentParser(description="Search federal grants on Grants.gov")
    parser.add_argument("keyword", help="Search term, e.g. 'renewable energy'")
    parser.add_argument(
        "--max-results", type=int, default=10, help="Number of results to show (default: 10)"
    )
    args = parser.parse_args()

    print(f"Searching Grants.gov for: '{args.keyword}'...")
    grants = search_grants(args.keyword, args.max_results)

    if not grants:
        print("No matching grants found. Try a different keyword.")
        return

    print(f"\nFound {len(grants)} result(s):")
    for grant in grants:
        print(format_grant(grant))


if _name_ == "_main_":
    main()
